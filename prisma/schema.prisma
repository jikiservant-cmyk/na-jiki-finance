generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas  = ["public"]
}

model applications {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                   String                   @unique
  name                   String
  base_url               String
  webhook_path           String                   @default("/api/internal/payment-completed")
  internal_secret_ref    String
  is_active               Boolean                  @default(true)
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  internal_notifications internal_notifications[]
  payment_intents        payment_intents[]
  payment_types          payment_types[]

  @@schema("public")
}

model internal_notifications {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payment_intent_id    String              @db.Uuid
  application_id       String              @db.Uuid
  url                  String
  payload              Json
  status               notification_status @default(pending)
  attempt_count        Int                 @default(0)
  max_attempts         Int                 @default(5)
  last_attempt_at      DateTime?           @db.Timestamptz(6)
  next_retry_at        DateTime?           @db.Timestamptz(6)
  last_response_status Int?
  last_response_body   String?
  created_at           DateTime            @default(now()) @db.Timestamptz(6)
  updated_at           DateTime            @default(now()) @db.Timestamptz(6)
  applications         applications        @relation(fields: [application_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payment_intents      payment_intents     @relation(fields: [payment_intent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([payment_intent_id], map: "idx_internal_notifications_intent")
  @@schema("public")
}

model payment_intents {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id         String                   @db.Uuid
  tenant_id              String?                  @db.Uuid
  payment_type_id        String?                  @db.Uuid
  external_entity_id     String?
  reference              String                   @unique
  idempotency_key        String                   @unique
  amount                 Decimal                  @db.Decimal(14, 2)
  currency               String                   @default("UGX")
  phone_number           String?
  provider_id            String                   @db.Uuid
  provider_payment_id    String?
  status                 payment_status           @default(pending)
  metadata               Json                     @default("{}")
  failure_reason         String?
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  completed_at           DateTime?                @db.Timestamptz(6)
  internal_notifications internal_notifications[]
  applications           applications             @relation(fields: [application_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payment_types          payment_types?           @relation(fields: [payment_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  providers              providers                @relation(fields: [provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenants                tenants?                 @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payment_transactions   payment_transactions[]
  webhook_logs           webhook_logs[]

  @@index([application_id], map: "idx_payment_intents_application")
  @@index([created_at], map: "idx_payment_intents_created_at")
  @@index([provider_payment_id], map: "idx_payment_intents_provider_payment_id")
  @@index([status], map: "idx_payment_intents_status")
  @@index([tenant_id], map: "idx_payment_intents_tenant")
  @@schema("public")
}

model payment_transactions {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payment_intent_id     String          @db.Uuid
  status                payment_status
  raw_provider_response Json?
  note                  String?
  created_at            DateTime        @default(now()) @db.Timestamptz(6)
  payment_intents       payment_intents @relation(fields: [payment_intent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at], map: "idx_payment_transactions_created_at")
  @@index([payment_intent_id], map: "idx_payment_transactions_intent")
  @@schema("public")
}

model payment_types {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id  String            @db.Uuid
  code            String
  description     String?
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  payment_intents payment_intents[]
  applications    applications      @relation(fields: [application_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([application_id, code])
  @@schema("public")
}

model providers {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String            @unique
  name            String
  credentials_ref String
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)
  payment_intents payment_intents[]
  webhook_logs    webhook_logs[]

  @@schema("public")
}

model tenants {
  id                  String                @id @db.Uuid
  app_type            String
  name                String?
  created_at          DateTime              @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  payment_intents     payment_intents[]

  @@schema("public")
}

model webhook_logs {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider_id       String           @db.Uuid
  payment_intent_id String?          @db.Uuid
  payload           Json
  headers           Json?
  signature_valid   Boolean
  processed         Boolean          @default(false)
  processing_error  String?
  created_at        DateTime         @default(now()) @db.Timestamptz(6)
  payment_intents   payment_intents? @relation(fields: [payment_intent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  providers         providers        @relation(fields: [provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at], map: "idx_webhook_logs_created_at")
  @@index([payment_intent_id], map: "idx_webhook_logs_intent")
  @@index([provider_id], map: "idx_webhook_logs_provider")
  @@schema("public")
}

enum notification_status {
  pending
  delivered
  failed_retrying
  failed_exhausted
  @@schema("public")
}

enum payment_status {
  pending
  processing
  success
  failed
  expired
  cancelled
  @@schema("public")
}
