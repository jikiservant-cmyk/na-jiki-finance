generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// === APPLICATIONS ===
// The apps allowed to use this payment service (sacco, church, school, ...)

model Application {
  id                String   @id @default(cuid())
  code              String   @unique             // 'sacco', 'church'
  name              String                       // 'SACCO Platform'
  baseUrl           String   @map("base_url")    // 'https://sacco.yourdomain.com'
  webhookPath       String   @map("webhook_path") @default("/api/internal/payment-completed")
  internalSecretRef String   @map("internal_secret_ref") // env var / vault key name — NEVER the secret itself
  isActive          Boolean  @map("is_active")  @default(true)
  createdAt         DateTime @map("created_at") @default(now())
  updatedAt         DateTime @map("updated_at") @updatedAt

  tenants           Tenant[]
  paymentTypes      PaymentType[]
  paymentIntents    PaymentIntent[]
  internalNotifications InternalNotification[]

  @@map("applications")
}

// === PROVIDERS ===
// The payment gateways this service talks to (livepay, relworx, ...)

model Provider {
  id              String   @id @default(cuid())
  code            String   @unique              // 'livepay', 'relworx'
  name            String
  credentialsRef  String   @map("credentials_ref") // env var / vault key prefix
  isActive        Boolean  @map("is_active")  @default(true)
  createdAt       DateTime @map("created_at") @default(now())
  updatedAt       DateTime @map("updated_at") @updatedAt

  tenants         Tenant[]
  paymentIntents  PaymentIntent[]
  webhookLogs     WebhookLog[]

  @@map("providers")
}

// === TENANTS ===
// A specific customer instance of an application.
// Lets "ABC SACCO" and "XYZ SACCO" run on the same codebase separately.

model Tenant {
  id               String     @id @default(cuid())
  applicationId    String     @map("application_id")
  application      Application @relation(fields: [applicationId], references: [id])
  code             String     // 'abc-sacco'
  name             String     // 'ABC SACCO'
  defaultProviderId String?   @map("default_provider_id")
  defaultProvider   Provider?  @relation(fields: [defaultProviderId], references: [id])
  isActive         Boolean    @map("is_active")  @default(true)
  createdAt        DateTime   @map("created_at") @default(now())
  updatedAt        DateTime   @map("updated_at") @updatedAt

  paymentIntents   PaymentIntent[]

  @@unique([applicationId, code])
  @@map("tenants")
}

// === PAYMENT TYPES ===
// Lookup table instead of hardcoded enum — each app adds its own types.

model PaymentType {
  id            String     @id @default(cuid())
  applicationId String     @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id])
  code          String     // 'deposit', 'loan_repayment', 'tithe'
  description   String?
  createdAt     DateTime   @map("created_at") @default(now())

  paymentIntents PaymentIntent[]

  @@unique([applicationId, code])
  @@map("payment_types")
}

// === PAYMENT INTENTS ===
// One row per attempted payment. Current-state snapshot.
// Full history lives in PaymentTransaction (append-only).

model PaymentIntent {
  id                String   @id @default(cuid())

  applicationId     String   @map("application_id")
  application       Application @relation(fields: [applicationId], references: [id])
  tenantId          String?  @map("tenant_id")
  tenant            Tenant?  @relation(fields: [tenantId], references: [id])
  paymentTypeId     String?  @map("payment_type_id")
  paymentType       PaymentType? @relation(fields: [paymentTypeId], references: [id])

  externalEntityId  String?  @map("external_entity_id") // member_id, invoice_id from the source app
  reference         String   @unique             // human-readable: SACCO-DEP-000123
  idempotencyKey    String   @map("idempotency_key") @unique // prevents duplicate intent creation

  amount            Decimal  @db.Decimal(14,2) // Numeric(14,2) for financial precision!
  currency          String   @default("UGX")
  phoneNumber       String?  @map("phone_number")

  providerId        String   @map("provider_id")
  provider          Provider @relation(fields: [providerId], references: [id])
  providerPaymentId String?  @map("provider_payment_id") // the provider's own transaction id

  status            String   @default("pending") // pending | processing | success | failed | expired | cancelled

  metadata          String   @default("{}")      // JSON — opaque, passed through from source app
  failureReason     String?  @map("failure_reason")

  createdAt         DateTime @map("created_at") @default(now())
  updatedAt         DateTime @map("updated_at") @updatedAt
  completedAt       DateTime? @map("completed_at")

  transactions      PaymentTransaction[]
  webhookLogs       WebhookLog[]
  internalNotifications InternalNotification[]

  @@index([applicationId])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@index([providerPaymentId])
  @@map("payment_intents")
}

// === PAYMENT TRANSACTIONS ===
// Append-only audit log. Every status change on PaymentIntent gets logged here.

model PaymentTransaction {
  id                  String   @id @default(cuid())
  paymentIntentId     String   @map("payment_intent_id")
  paymentIntent       PaymentIntent @relation(fields: [paymentIntentId], references: [id])
  status              String                       // matches the status that was set
  rawProviderResponse String?  @map("raw_provider_response") // JSON — exact payload from provider
  note                String?
  createdAt           DateTime @map("created_at") @default(now())

  @@index([paymentIntentId])
  @@index([createdAt])
  @@map("payment_transactions")
}

// === WEBHOOK LOGS ===
// Every webhook received, valid or not. Evidence trail for disputes and debugging.

model WebhookLog {
  id                String   @id @default(cuid())
  providerId        String   @map("provider_id")
  provider          Provider @relation(fields: [providerId], references: [id])
  paymentIntentId   String?  @map("payment_intent_id") // nullable — may not be resolvable yet
  paymentIntent     PaymentIntent? @relation(fields: [paymentIntentId], references: [id])

  payload           String                       // JSON
  headers           String?                      // JSON — signature header etc.
  signatureValid    Boolean  @map("signature_valid")
  processed         Boolean  @default(false)
  processingError   String?  @map("processing_error")
  createdAt         DateTime @map("created_at") @default(now())

  @@index([providerId])
  @@index([paymentIntentId])
  @@index([createdAt])
  @@map("webhook_logs")
}

// === INTERNAL NOTIFICATIONS ===
// Tracks delivery of "payment completed" callbacks back to the source app.
// Supports retry: cron polls status in ('pending','failed_retrying') and nextRetryAt <= now()

model InternalNotification {
  id                String   @id @default(cuid())
  paymentIntentId   String   @map("payment_intent_id")
  paymentIntent     PaymentIntent @relation(fields: [paymentIntentId], references: [id])
  applicationId     String   @map("application_id")
  application       Application @relation(fields: [applicationId], references: [id])

  url               String                       // target callback URL
  payload           String                       // JSON — exact snapshot sent

  status            String   @default("pending") // pending | delivered | failed_retrying | failed_exhausted
  attemptCount      Int      @map("attempt_count")  @default(0)
  maxAttempts       Int      @map("max_attempts")  @default(5)

  lastAttemptAt     DateTime? @map("last_attempt_at")
  nextRetryAt       DateTime? @map("next_retry_at")

  lastResponseStatus Int?   @map("last_response_status") // HTTP status code
  lastResponseBody  String? @map("last_response_body")

  createdAt         DateTime @map("created_at") @default(now())
  updatedAt         DateTime @map("updated_at") @updatedAt

  @@index([paymentIntentId])
  @@map("internal_notifications")
}
