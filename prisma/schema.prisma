generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas  = ["public"]
}

model Application {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                   String                   @unique
  name                   String
  baseUrl                String                   @map("base_url")
  webhookPath            String                   @map("webhook_path") @default("/api/internal/payment-completed")
  internalSecretRef      String                   @map("internal_secret_ref")
  isActive               Boolean                  @map("is_active") @default(true)
  createdAt              DateTime                 @map("created_at") @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime                 @map("updated_at") @default(now()) @db.Timestamptz(6)
  internalNotifications  InternalNotification[]
  paymentIntents         PaymentIntent[]
  paymentTypes           PaymentType[]

  @@map("applications")
  @@schema("public")
}

model InternalNotification {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentIntentId      String              @map("payment_intent_id") @db.Uuid
  applicationId        String              @map("application_id") @db.Uuid
  url                  String
  payload              Json
  status               NotificationStatus @default(pending)
  attemptCount         Int                 @map("attempt_count") @default(0)
  maxAttempts          Int                 @map("max_attempts") @default(5)
  lastAttemptAt        DateTime?           @map("last_attempt_at") @db.Timestamptz(6)
  nextRetryAt          DateTime?           @map("next_retry_at") @db.Timestamptz(6)
  lastResponseStatus   Int?                @map("last_response_status")
  lastResponseBody     String?              @map("last_response_body")
  createdAt            DateTime            @map("created_at") @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime            @map("updated_at") @default(now()) @db.Timestamptz(6)
  application          Application         @relation(fields: [applicationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paymentIntent        PaymentIntent       @relation(fields: [paymentIntentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([paymentIntentId], map: "idx_internal_notifications_intent")
  @@map("internal_notifications")
  @@schema("public")
}

model PaymentIntent {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId          String                   @map("application_id") @db.Uuid
  tenantId               String?                  @map("tenant_id") @db.Uuid
  paymentTypeId          String?                  @map("payment_type_id") @db.Uuid
  externalEntityId       String?                  @map("external_entity_id")
  reference              String                   @unique
  idempotencyKey         String                   @map("idempotency_key") @unique
  amount                 Decimal                  @db.Decimal(14, 2)
  currency               String                   @default("UGX")
  phoneNumber            String?                  @map("phone_number")
  providerId             String                   @map("provider_id") @db.Uuid
  providerPaymentId      String?                  @map("provider_payment_id")
  status                 PaymentStatus           @default(pending)
  metadata               Json                     @default("{}")
  failureReason          String?                  @map("failure_reason")
  createdAt              DateTime                 @map("created_at") @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime                 @map("updated_at") @default(now()) @db.Timestamptz(6)
  completedAt            DateTime?                @map("completed_at") @db.Timestamptz(6)
  internalNotifications  InternalNotification[]
  application            Application             @relation(fields: [applicationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paymentType            PaymentType?             @relation(fields: [paymentTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  provider               Provider                @relation(fields: [providerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant                 Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paymentTransactions    PaymentTransaction[]
  webhookLogs            WebhookLog[]

  @@index([applicationId], map: "idx_payment_intents_application")
  @@index([createdAt], map: "idx_payment_intents_created_at")
  @@index([providerPaymentId], map: "idx_payment_intents_provider_payment_id")
  @@index([status], map: "idx_payment_intents_status")
  @@index([tenantId], map: "idx_payment_intents_tenant")
  @@map("payment_intents")
  @@schema("public")
}

model PaymentTransaction {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentIntentId       String          @map("payment_intent_id") @db.Uuid
  status                PaymentStatus
  rawProviderResponse   Json?           @map("raw_provider_response")
  note                  String?
  createdAt             DateTime        @map("created_at") @default(now()) @db.Timestamptz(6)
  paymentIntent         PaymentIntent   @relation(fields: [paymentIntentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([createdAt], map: "idx_payment_transactions_created_at")
  @@index([paymentIntentId], map: "idx_payment_transactions_intent")
  @@map("payment_transactions")
  @@schema("public")
}

model PaymentType {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId   String            @map("application_id") @db.Uuid
  code            String
  description     String?
  createdAt       DateTime          @map("created_at") @default(now()) @db.Timestamptz(6)
  paymentIntents  PaymentIntent[]
  application     Application       @relation(fields: [applicationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([applicationId, code])
  @@map("payment_types")
  @@schema("public")
}

model Provider {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String            @unique
  name            String
  credentialsRef  String            @map("credentials_ref")
  isActive        Boolean           @map("is_active") @default(true)
  createdAt       DateTime          @map("created_at") @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime          @map("updated_at") @default(now()) @db.Timestamptz(6)
  paymentIntents  PaymentIntent[]
  webhookLogs     WebhookLog[]

  @@map("providers")
  @@schema("public")
}

model Tenant {
  id               String                @id @db.Uuid
  appType          String                @map("app_type")
  name             String?
  createdAt        DateTime              @map("created_at") @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  paymentIntents   PaymentIntent[]

  @@map("tenants")
  @@schema("public")
}

model WebhookLog {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId        String           @map("provider_id") @db.Uuid
  paymentIntentId   String?          @map("payment_intent_id") @db.Uuid
  payload           Json
  headers           Json?
  signatureValid    Boolean          @map("signature_valid")
  processed         Boolean          @default(false)
  processingError   String?          @map("processing_error")
  createdAt         DateTime         @map("created_at") @default(now()) @db.Timestamptz(6)
  paymentIntent     PaymentIntent?   @relation(fields: [paymentIntentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  provider          Provider         @relation(fields: [providerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([createdAt], map: "idx_webhook_logs_created_at")
  @@index([paymentIntentId], map: "idx_webhook_logs_intent")
  @@index([providerId], map: "idx_webhook_logs_provider")
  @@map("webhook_logs")
  @@schema("public")
}

enum NotificationStatus {
  pending
  delivered
  failed_retrying
  failed_exhausted
  @@schema("public")
}

enum PaymentStatus {
  pending
  processing
  success
  failed
  expired
  cancelled
  @@schema("public")
}
